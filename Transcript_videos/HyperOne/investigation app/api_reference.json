{
  "meta": {
    "product": "HyperOne CRM",
    "version": "4.0.136",
    "base_host": "https://demo.hypernet.pro",
    "extracted_date": "2026-03-03",
    "discovery_method": "network traffic interception via browser devtools",
    "notes": "No public API docs (/swagger, /redoc, /openapi.json all return 404). All endpoints discovered empirically."
  },

  "auth": {
    "type": "Bearer Session UUID",
    "header": "Authorization: Bearer <uuid>",
    "token_format": "UUID v4 (NOT JWT — no dot-separated structure)",
    "storage": "localStorage key 'InNlc3Npb25LZXki' (base64 for '\"sessionKey\"'), value is base64-encoded JSON string",
    "decode": "atob(localStorage.getItem('InNlc3Npb25LZXki')) → JSON.parse → UUID string",
    "session_key_b64": "InNlc3Npb25LZXki",
    "active_company_key_b64": "ImFjdGl2ZUNvbXBhbnlJZCI=",
    "expiry": "sessions expire mid-usage requiring re-login (no visible refresh token)",
    "login_flow": "Angular reactive form POST to auth service → session UUID returned and stored in localStorage"
  },

  "microservices": [
    {
      "name": "tracker",
      "prefix": "/api/tracker/",
      "purpose": "Core CRM: leads, brands, hubs, affiliates, accounts, metrics, fraud, conversions"
    },
    {
      "name": "auth",
      "prefix": "/api/auth/",
      "purpose": "Authentication and user/company profile management"
    },
    {
      "name": "injector",
      "prefix": "/api/injector/",
      "purpose": "UAD (User Action Director) — automated lead re-injection scenarios"
    },
    {
      "name": "geo",
      "prefix": "/api/geo/",
      "purpose": "Geographic reference data: countries, languages, timezones"
    }
  ],

  "conventions": {
    "pagination": "?skip=N&take=N (default take=10)",
    "sorting": "?sort[fieldName]=asc|desc",
    "filtering": "?filter[fieldName]=value OR ?filter[fieldName][gte]=value &filter[fieldName][lte]=value",
    "filter_operators": ["gte", "lte", "eq", "ne", "in", "like"],
    "list_vs_paginated": {
      "/list": "Returns full unfiltered/unpaginated array (used for select dropdowns)",
      "no-/list": "Returns paginated response with skip/take"
    },
    "entity_codes": "Short human-readable codes with prefix (BR-, BX-, AFF-, BI-, SCN-, FP-, VT-)"
  },

