  "pages": [

    {
      "id": "metrics",
      "module": 1,
      "title": "Метрики",
      "route": "#/dashboard/metrics",
      "api_calls": [
        "GET /api/tracker/statistic/statusGroup",
        "GET /api/tracker/statistic/geo",
        "GET /api/tracker/statistic/leads",
        "GET /api/tracker/statistic/affiliates",
        "GET /api/tracker/statistic/brands",
        "GET /api/tracker/statistic/hubs",
        "GET /api/tracker/statistic/attribute/subId_a",
        "GET /api/tracker/statistic/attribute/utmId",
        "GET /api/tracker/statistic/attribute/autologinStatus",
        "GET /api/tracker/statistic/attribute/funnel",
        "GET /api/tracker/statistic/attribute/lang",
        "GET /api/tracker/statistic/status"
      ],
      "layout": "dashboard with filter bar + widget grid",
      "filter_bar": {
        "date_range": "preset + custom (gte/lte)",
        "status_group_selector": "dropdown (statusGroup=brandStatusGroup|affiliateStatusGroup)",
        "dimensions": "27 total (subId_a, utmId, autologinStatus, funnel, lang, geo, affiliate, brand, hub, etc.)"
      },
      "widgets": [
        { "type": "stat_cards", "metrics": ["total leads", "registered", "deposited", "ftd rate"] },
        { "type": "line_chart", "data": "leads over time (scale: month/week/day)" },
        { "type": "table", "data": "top affiliates by deposit" },
        { "type": "table", "data": "top brands by deposit" },
        { "type": "table", "data": "top hubs by deposit" },
        { "type": "table", "data": "breakdown by selected attribute dimension" },
        { "type": "table", "data": "status group breakdown" },
        { "type": "table", "data": "GEO breakdown" }
      ],
      "toolbar": ["date range filter", "dimension selector", "status group toggle", "refresh", "export"]
    },

