      "toolbar": [
        { "icon": "+", "tooltip": "Створити ліда", "action": "navigate to #/dashboard/leads/create" },
        { "icon": "↻", "tooltip": "Оновити" },
        { "icon": "←", "tooltip": "Назад" },
        { "icon": "funnel", "tooltip": "Фільтр", "has_badge": true },
        { "icon": "cloud↑", "tooltip": "Імпорт" }
