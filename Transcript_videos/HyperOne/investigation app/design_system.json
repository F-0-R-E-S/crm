  "layout": {
    "type": "fixed_sidebar_top_header",
    "sidebar": {
      "position": "left",
      "expandable": true,
      "toggle_icon": "chevron",
      "logo_area": "top of sidebar",
      "logout_button": "bottom of sidebar",
      "active_item_indicator": "left border accent gradient"
    },
    "header": {
      "position": "top-right overlay",
      "content": "current datetime (timezone Europe/Berlin), user name, role badge, avatar button"
    },
    "main_content": {
      "layout": "full width with padding",
      "page_title_bar": "sticky top with page title, result count, toolbar actions"
    }
  },

  "components": {
    "button_primary": {
      "background": "linear-gradient(92.69deg, #fea04c 0%, #e5508a 100%)",
      "text_color": "#ffffff",
      "border_radius": "6px",
      "padding": "8px 24px",
      "font_weight": 600,
      "hover": "opacity 0.9",
      "examples": ["Створити бренд", "Зберегти", "Застосувати"]
    },
    "button_secondary": {
      "background": "transparent",
      "text_color": "rgba(255,255,255,0.7)",
      "border": "1px solid rgba(255,255,255,0.2)",
      "border_radius": "6px",
      "padding": "8px 24px",
      "examples": ["Скасувати", "Повернутись"]
    },
    "button_icon": {
      "background": "rgba(255,255,255,0.06)",
      "size": "36px",
      "border_radius": "6px",
      "icon_color": "rgba(255,255,255,0.7)",
      "tooltip": "always present",
      "examples": ["Refresh", "Filter", "Export", "Back"]
    },
    "table": {
      "header_bg": "#1e1d2e",
      "header_text": "rgba(255,255,255,0.6)",
      "header_font_weight": 500,
      "row_bg": "#252434",
      "row_bg_hover": "rgba(255,255,255,0.04) overlay",
      "row_border": "1px solid rgba(255,255,255,0.05) bottom",
      "sortable_indicator": "arrow icon on sorted column",
      "pagination": "mat-paginator at bottom",
      "page_sizes": [10, 25, 50, 100],
      "actions": "settings gear icon opens context menu per row"
    },
    "form_field": {
      "background": "#3a374a",
      "border_radius": "6px",
      "border": "1px solid rgba(255,255,255,0.1)",
      "border_focused": "1px solid rgba(254,160,76,0.6)",
      "label_position": "above field (not floating)",
      "text_color": "#ffffff",
      "placeholder_color": "rgba(255,255,255,0.35)"
    },
    "mat_select": {
      "arrow": "keyboard_arrow_down Material icon",
      "panel_bg": "#252434",
      "option_hover": "rgba(255,255,255,0.08)",
      "option_selected": "rgba(254,160,76,0.15)"
    },
    "toggle_switch": {
      "on_color": "#fea04c",
      "off_color": "rgba(255,255,255,0.2)",
      "size": "standard mat-slide-toggle"
    },
    "checkbox": {
      "checked_color": "#fea04c",
      "border": "rgba(255,255,255,0.4)"
    },
    "radio_button": {
      "selected_color": "#fea04c",
      "usage": "Вертикалі list — single row selection"
    },
    "badge_chip": {
      "variants": ["valid/green", "invalid/red", "deposit/green", "refusal/red", "test/gray"],
      "border_radius": "4px",
      "padding": "2px 8px",
      "font_size": "12px"
    },
    "profile_card": {
      "bg": "#252434",
      "border_radius": "8px",
      "padding": "20px",
      "header": "section title + optional gear/settings icon"
    },
    "tabs": {
      "type": "mat-tab-group / custom router-linked tabs",
      "active_indicator": "bottom border gradient",
      "text_active": "#ffffff",
      "text_inactive": "rgba(255,255,255,0.5)"
    },
    "tooltip": {
      "trigger": "hover on icon buttons and filter-chips",
      "bg": "#3a374a",
      "text": "#ffffff",
      "border_radius": "4px"
    },
    "search_bar": {
      "position": "top of table card",
      "icon": "search (magnifying glass)",
      "placeholder": "Пошук",
      "full_width": false,
      "behavior": "debounced filter on API"
    },
    "sidebar_item": {
      "normal": "icon + label, rgba(255,255,255,0.5) text",
      "active": "icon + label, white text, gradient left border",
      "icon_set": "custom SVG icons (Stockholm-icons set)",
      "collapse_toggle": "chevron button at top of sidebar"
    },
    "system_indicator": {
      "pattern": "colored dot + title + description + optional toggle",
      "green_dot": "active/positive state",
      "red_dot": "inactive/negative state",
      "toggle": "mat-slide-toggle for on/off states"
    },
    "stat_widget": {
      "usage": "Metrics page dashboard",
      "bg": "#252434",
      "border_radius": "8px",
      "has_chart": true,
      "chart_library": "inferred from bundle (likely Chart.js or ng2-charts)"
    }
