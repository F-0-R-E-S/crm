      "api_endpoint": "POST /api/tracker/account/resources/botSubscriber",
      "fields": [
        { "name": "botToken", "label": "Токен бота", "type": "text", "required": true, "note": "BotFather-issued token" },
        { "name": "chatId", "label": "Chat ID", "type": "text", "required": true },
        { "name": "events", "label": "События", "type": "mat-select-multi", "note": "Up to 17 event types", "options": [
          "Лід створений", "Лід відправлений", "Статус змінено", "Депозит отримано",
          "Фрод виявлено", "Конверсія", "Помилка відправки", "Автологін активовано",
          "Новий акаунт", "Постбек отримано", "Ліміт кап досягнуто",
          "Аномалія статусу", "Інжекція виконана", "Сценарій запущено",
          "Бот підключено", "Бот відключено", "Системна подія"
        ]}
      ]
    },

    "uad_scenario_create": {
      "title": "UAD Сценарій",
      "route": "#/dashboard/scenarios/create",
      "api_endpoint": "POST /api/injector/scenario",
      "note": "User Action Director — automated lead re-injection engine on separate microservice",
      "fields": [
        { "name": "name", "label": "Назва", "type": "text", "required": true },
        { "name": "code", "label": "Код", "type": "readonly", "format": "SCN-XXXXXXXXXX" },
        { "name": "triggerEvent", "label": "Тригер подія", "type": "mat-select", "options": ["Статус змінено", "Час без відповіді", "Без депозиту X днів", "Відмова N разів"] },
        { "name": "conditions", "label": "Умови", "type": "condition_builder", "note": "AND/OR logic for GEO, affiliate, hub, status group filters" },
        { "name": "actions", "label": "Дії", "type": "action_builder", "note": "Re-inject lead to hub, change status, send notification" },
        { "name": "isActive", "label": "Активний", "type": "toggle", "default": true }
      ]
    },

    "conversion_hold_config": {
      "title": "Налаштування конверсій",
      "route": "#/dashboard/conversions",
      "api_endpoint": "GET/PATCH /api/tracker/company/resources/conversionHold",
      "fields": [
        { "name": "holdTimer", "label": "Таймер холду", "type": "number", "unit": "minutes/hours" },
        { "name": "stopStatuses", "label": "Стоп-статуси", "type": "mat-select-multi", "source": "status list", "note": "Statuses that halt conversion hold" }
      ]
    },

    "login": {
      "title": "Вхід",
      "route": "#/auth/login",
      "api_endpoint": "POST /api/auth (via Angular form + redirect)",
      "fields": [
        { "name": "email", "label": "Email", "type": "email", "required": true, "placeholder": "email@example.com" },
        { "name": "password", "label": "Пароль", "type": "password", "required": true }
      ],
      "actions": [
        { "label": "Увійти", "type": "primary" }
      ],
      "notes": "Angular reactive form. Cannot use programmatic .value= assignment — must simulate keyboard events. Session UUID stored in localStorage."
    }
  }
}
