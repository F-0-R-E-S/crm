{
  "meta": {
    "product": "HyperOne CRM",
    "version": "4.0.136",
    "extracted_date": "2026-03-03",
    "source": "demo.hypernet.pro",
    "notes": "All forms use Angular Reactive Forms. Labels are in Ukrainian. Dropdowns call /api/tracker/{entity}/list for options."
  },

  "forms": {

    "brand_create": {
      "title": "Створення бренду",
      "route": "#/dashboard/brands/create",
      "api_endpoint": "POST /api/tracker/broker",
      "breadcrumb": "Всі бренди",
      "fields": [
        { "name": "name", "label": "Ім'я", "type": "text", "placeholder": "John Doe", "required": true },
        { "name": "url", "label": "URL", "type": "text", "placeholder": "https://keenthe.com/some/any?id=1", "required": false },
        { "name": "description", "label": "Опис", "type": "textarea", "placeholder": "...", "required": false },
        { "name": "isSynchronized", "label": "Синхронізований", "type": "checkbox", "default": false },
        { "name": "isSending", "label": "Надсилається", "type": "checkbox", "default": false },
        { "name": "isPostback", "label": "Постбек", "type": "checkbox", "default": false }
      ],
      "actions": [
        { "label": "Скасувати", "type": "secondary", "action": "navigate_back" },
        { "label": "Створити бренд", "type": "primary", "action": "submit" }
      ]
    },

    "brand_edit": {
      "title": "Редагування бренду",
      "route": "#/dashboard/brands/{id}/primary",
      "api_endpoint": "PATCH /api/tracker/broker/{id}",
      "fields": [
        { "name": "name", "label": "Ім'я", "type": "text", "inline_edit": true },
        { "name": "url", "label": "URL", "type": "text", "inline_edit": true },
        { "name": "description", "label": "Опис", "type": "textarea", "inline_edit": true },
        { "name": "isSynchronized", "label": "Синхронізований", "type": "toggle", "inline": true },
        { "name": "isSending", "label": "Надсилається", "type": "toggle", "inline": true },
        { "name": "isPostback", "label": "Постбек", "type": "toggle", "inline": true },
        { "name": "isFraudBlocking", "label": "Блокування фрода", "type": "toggle", "inline": true }
      ],
      "notes": "Edit done inline on profile page via pencil icon or Управління button"
    },

    "hub_create": {
      "title": "Створення хаба",
      "route": "#/dashboard/hubs/create",
      "api_endpoint": "POST /api/tracker/box",
      "breadcrumb": "Всі хаби",
      "fields": [
        { "name": "name", "label": "Назва", "type": "text", "placeholder": "John Doe", "required": true },
        { "name": "verticalTemplateId", "label": "Вертикаль", "type": "mat-select", "placeholder": "Base", "source": "GET /api/tracker/verticalTemplate", "required": true },
        { "name": "description", "label": "Опис", "type": "textarea", "placeholder": "...", "required": false },
        { "name": "isSending", "label": "Надсилається", "type": "checkbox", "default": true }
      ],
      "actions": [
        { "label": "Скасувати", "type": "secondary", "action": "navigate_back" },
        { "label": "Створити хаб", "type": "primary", "action": "submit" }
      ]
    },

    "affiliate_create": {
      "title": "Створення афілейту",
      "route": "#/dashboard/affiliates/create",
      "api_endpoint": "POST /api/tracker/affiliate",
      "breadcrumb": "Всі афілейти",
      "note_shown": "Після створення афілейту за первинною інформацією - перейдіть до створення postback налаштувань для подальшої інтеграції",
      "fields": [
        { "name": "name", "label": "Ім'я", "type": "text", "placeholder": "John Doe", "required": true },
        { "name": "description", "label": "Опис", "type": "textarea", "placeholder": "John Doe: Any", "required": false }
      ],
      "actions": [
        { "label": "Скасувати", "type": "secondary", "action": "navigate_back" },
        { "label": "Створити афілейту", "type": "primary", "action": "submit" }
      ]
    },

    "affiliate_profile": {
      "title": "Профіль афілейту",
      "route": "#/dashboard/affiliates/{id}/primary",
      "fields": [
        { "name": "name", "label": "Ім'я", "type": "text", "inline_edit": true },
        { "name": "code", "label": "Код", "type": "readonly", "format": "AFF-XXXXXXXXXX" },
        { "name": "description", "label": "Опис", "type": "textarea", "inline_edit": true },
        { "name": "autologinDomain", "label": "Домен автологіна", "type": "text", "inline_edit": true },
        { "name": "unassignedLeadPostbackType", "label": "Тип постбеку для непризначених лідів", "type": "select", "options": ["Ліда відхилено"] },
        { "name": "apiKey", "label": "API ключ", "type": "readonly", "format": "UUID v4" },
        { "name": "balance", "label": "Баланс", "type": "readonly", "format": "$" }
      ],
      "system_indicators": [
        { "name": "conversionHold", "label": "Холд конверсій", "type": "toggle" },
        { "name": "realtimeFraudCheck", "label": "Перевірка на фрод у реальному часі", "type": "toggle" },
        { "name": "affiliateStatusSync", "label": "Синхр. афілейт статусу", "type": "toggle", "depends_on": "conversionHold" },
        { "name": "showUnassignedLeads", "label": "Відображення непризначених лідів", "type": "toggle" },
        { "name": "showRefusalLeads", "label": "Відображення лідів у статусі 'Відмова'", "type": "toggle" },
        { "name": "autologinDeviceCheck", "label": "Перевірка пристрою автологіна", "type": "toggle" },
        { "name": "useStatusGroupInsteadOfStatus", "label": "Використовувати статус групу замість статусу", "type": "toggle" },
        { "name": "phoneValidation", "label": "Валідація телефону", "type": "toggle" },
        { "name": "emailValidation", "label": "Валідація email", "type": "toggle" },
        { "name": "redirectActivation", "label": "Активація редиректу", "type": "toggle" },
        { "name": "apiKeyRequired", "label": "API ключ обов'язковий для відправки", "type": "toggle" }
      ]
    },

