    "account_create": {
      "title": "Створення облікового запису",
      "route": "#/dashboard/accounts/create",
      "api_endpoint": "POST /api/tracker/account",
      "breadcrumb": "Всі облікові записи",
      "type": "multi_step_wizard",
      "steps": [
        {
          "step": 1,
          "title": "Перевірка Email",
          "note": "Перед створенням облікового запису давайте перевіримо, чи немає в нашій системі облікового запису з таким же e-mail.",
          "fields": [
            { "name": "email", "label": "Email", "type": "email", "required": true }
          ],
          "action": { "label": "Перевірити e-mail", "api": "GET /api/tracker/account?filter[email]={email}" }
        },
        {
          "step": 2,
          "title": "Дані облікового запису",
          "note": "Shown if email not found in step 1",
          "fields": [
            { "name": "firstName", "label": "Ім'я", "type": "text", "required": true },
            { "name": "lastName", "label": "Прізвище", "type": "text", "required": true },
            { "name": "phone", "label": "Телефон", "type": "tel" },
            { "name": "affiliateId", "label": "Афілейт", "type": "mat-select", "source": "GET /api/tracker/affiliate/list" },
            { "name": "geo", "label": "ГЕО", "type": "mat-select", "source": "GET /api/geo/countries" }
          ]
        }
      ]
    },

