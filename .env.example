# --- Database ---
DATABASE_URL="postgresql://crm:crm@localhost:5432/crm?schema=public"

# --- NextAuth ---
AUTH_SECRET="replace-me-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# --- Redis (rate limit + VOIP cache) ---
REDIS_URL="redis://localhost:6379"

# --- Anti-fraud ---
ANTIFRAUD_DEDUP_WINDOW_DAYS=7
ANTIFRAUD_VOIP_CHECK_ENABLED=false
NUMVERIFY_API_KEY=
ANTIFRAUD_VOIP_TIMEOUT_MS=3000
ANTIFRAUD_VOIP_CACHE_DAYS=30

# --- Observability ---
LOG_LEVEL=info
