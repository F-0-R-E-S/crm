# GambChamp CRM — Environment Variables
# Copy this to .env and adjust values

# Database
DATABASE_URL=postgres://gambchamp:gambchamp@localhost:5432/gambchamp?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# NATS
NATS_URL=nats://localhost:4222

# JWT
JWT_SECRET=change-me-in-production-use-64-chars-minimum
JWT_REFRESH_SECRET=change-me-too-in-production-use-64-chars

# Server
PORT=8080
LOG_LEVEL=debug
ENVIRONMENT=development

# Bcrypt
BCRYPT_COST=12
