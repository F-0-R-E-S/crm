generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         UserRole   @default(OPERATOR)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
}

enum UserRole {
  ADMIN
  OPERATOR
}

model Affiliate {
  id                String             @id @default(cuid())
  name              String
  contactEmail      String?
  isActive          Boolean            @default(true)
  totalDailyCap     Int?
  postbackUrl       String?
  postbackSecret    String?
  postbackEvents    String[]           @default([])
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  apiKeys           ApiKey[]
  leads             Lead[]
  outboundPostbacks OutboundPostback[]
  intakeSettings    IntakeSettings?
  intakeWebhooks    AffiliateIntakeWebhook[]

  @@index([isActive])
}

model AffiliateIntakeWebhook {
  id           String            @id @default(cuid())
  affiliateId  String
  url          String
  secret       String
  events       String[]          @default([])
  isActive     Boolean           @default(true)
  pausedAt     DateTime?
  pausedReason String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  affiliate    Affiliate         @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  deliveries   WebhookDelivery[]

  @@index([affiliateId, isActive])
}

model WebhookDelivery {
  id            String                 @id @default(cuid())
  webhookId     String
  eventType     String
  payload       Json
  signature     String
  attempt       Int                    @default(0)
  lastStatus    Int?
  lastError     String?
  nextAttemptAt DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime               @default(now())
  webhook       AffiliateIntakeWebhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, createdAt])
  @@index([nextAttemptAt])
}

model IntakeSettings {
  affiliateId      String    @id
  requiredFields   String[]  @default([])
  allowedGeo       String[]  @default([])
  dedupeWindowDays Int       @default(30)
  maxRpm           Int       @default(120)
  acceptSchedule   Json      @default("{}")
  version          Int       @default(1)
  updatedBy        String?
  updatedAt        DateTime  @updatedAt
  createdAt        DateTime  @default(now())
  affiliate        Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id          String    @id @default(cuid())
  affiliateId String
  keyHash     String    @unique
  keyPrefix   String
  label       String
  lastUsedAt  DateTime?
  isRevoked   Boolean   @default(false)
  isSandbox   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId, isRevoked])
}

model Broker {
  id                 String         @id @default(cuid())
  name               String
  isActive           Boolean        @default(true)
  dailyCap           Int?
  workingHours       Json?
  endpointUrl        String
  httpMethod         HttpMethod     @default(POST)
  headers            Json           @default("{}")
  authType           BrokerAuthType @default(NONE)
  authConfig         Json           @default("{}")
  fieldMapping       Json
  staticPayload      Json           @default("{}")
  responseIdPath     String?
  postbackSecret     String
  postbackLeadIdPath String
  postbackStatusPath String
  statusMapping      Json           @default("{}")
  templateId         String?
  template           BrokerTemplate? @relation(fields: [templateId], references: [id])
  syncMode           String         @default("webhook")
  pollIntervalMin    Int?
  pendingHoldMinutes Int?
  statusPollPath     String?
  statusPollIdsParam String?
  lastHealthStatus   String         @default("unknown")
  lastHealthCheckAt  DateTime?
  lastPolledAt       DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  rotationRules      RotationRule[]
  leads              Lead[]
  healthChecks       BrokerHealthCheck[]
  errorSamples       BrokerErrorSample[]

  @@index([isActive])
  @@index([syncMode, isActive])
  @@index([templateId])
}

enum HttpMethod {
  POST
  PUT
}

enum BrokerAuthType {
  NONE
  BEARER
  BASIC
  API_KEY_HEADER
  API_KEY_QUERY
}

model RotationRule {
  id       String  @id @default(cuid())
  geo      String
  brokerId String
  priority Int
  isActive Boolean @default(true)
  broker   Broker  @relation(fields: [brokerId], references: [id], onDelete: Cascade)

  @@unique([geo, brokerId])
  @@index([geo, isActive, priority])
}

model Lead {
  id                String             @id @default(cuid())
  externalLeadId    String?
  affiliateId       String
  brokerId          String?
  state             LeadState          @default(NEW)
  rejectReason      String?
  firstName         String?
  lastName          String?
  email             String?
  phone             String?
  phoneHash         String?
  emailHash         String?
  geo               String
  ip                String
  landingUrl        String?
  subId             String?
  utm               Json               @default("{}")
  normalizationWarnings Json           @default("[]")
  rawPayload        Json               @default("{}")
  eventTs           DateTime
  brokerExternalId  String?
  lastBrokerStatus  String?
  lastPushAt        DateTime?
  acceptedAt        DateTime?
  ftdAt             DateTime?
  pendingHoldUntil  DateTime?
  shaveSuspected    Boolean            @default(false)
  traceId           String             @unique
  receivedAt        DateTime           @default(now())
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  affiliate         Affiliate          @relation(fields: [affiliateId], references: [id])
  broker            Broker?            @relation(fields: [brokerId], references: [id])
  events            LeadEvent[]
  outboundPostbacks OutboundPostback[]

  @@index([affiliateId, createdAt])
  @@index([brokerId, createdAt])
  @@index([geo, state])
  @@index([phoneHash])
  @@index([emailHash])
  @@index([state, createdAt])
  @@index([externalLeadId, affiliateId])
}

enum LeadState {
  NEW
  VALIDATING
  REJECTED
  PUSHING
  PUSHED
  PENDING_HOLD
  ACCEPTED
  DECLINED
  FTD
  FAILED
}

model LeadEvent {
  id        String        @id @default(cuid())
  leadId    String
  kind      LeadEventKind
  meta      Json          @default("{}")
  prevHash  String?
  rowHash   String?
  createdAt DateTime      @default(now())
  lead      Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
}

enum LeadEventKind {
  RECEIVED
  VALIDATION_FAIL
  REJECTED_ANTIFRAUD
  ROUTING_DECIDED
  CAP_BLOCKED
  NO_BROKER_AVAILABLE
  BROKER_PUSH_ATTEMPT
  BROKER_PUSH_SUCCESS
  BROKER_PUSH_FAIL
  POSTBACK_RECEIVED
  STATE_TRANSITION
  MANUAL_OVERRIDE
  OUTBOUND_POSTBACK_SENT
  OUTBOUND_POSTBACK_FAILED
  FLOW_FILTER_REJECT
  FALLBACK_HOP
  SIMULATE_DECISION
  PENDING_HOLD_STARTED
  PENDING_HOLD_RELEASED
  SHAVE_SUSPECTED
}

model IdempotencyKey {
  key          String   @id
  affiliateId  String
  leadId       String?
  payloadHash  String   @default("")
  responseCode Int
  responseBody Json
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@unique([affiliateId, key])
  @@index([expiresAt])
}

model DailyCap {
  id      String   @id @default(cuid())
  scope   CapScope
  scopeId String
  day     DateTime
  count   Int      @default(0)

  @@unique([scope, scopeId, day])
  @@index([day])
}

enum CapScope {
  AFFILIATE
  BROKER
  FLOW
  BRANCH
  TARGET
}

model Blacklist {
  id        String        @id @default(cuid())
  kind      BlacklistKind
  value     String
  reason    String?
  createdBy String?
  createdAt DateTime      @default(now())

  @@unique([kind, value])
  @@index([kind])
}

enum BlacklistKind {
  IP_CIDR
  IP_EXACT
  EMAIL_DOMAIN
  PHONE_E164
}

model PostbackReceipt {
  id        String   @id @default(cuid())
  brokerId  String
  payload   Json
  headers   Json
  verified  Boolean
  leadId    String?
  traceId   String
  createdAt DateTime @default(now())

  @@index([brokerId, createdAt])
  @@index([leadId])
}

model OutboundPostback {
  id           String    @id @default(cuid())
  leadId       String
  affiliateId  String
  event        String
  url          String
  httpStatus   Int?
  requestBody  Json?
  responseBody Json?
  errorMessage String?
  attemptN     Int       @default(1)
  deliveredAt  DateTime?
  nextRetryAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lead         Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  affiliate    Affiliate @relation(fields: [affiliateId], references: [id])

  @@index([affiliateId, createdAt])
  @@index([leadId, createdAt])
  @@index([deliveredAt, nextRetryAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  diff      Json     @default("{}")
  traceId   String?
  prevHash  String?
  rowHash   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([entity, entityId])
}

// --- EPIC-02 Routing Engine ---

model Flow {
  id              String        @id @default(cuid())
  name            String
  timezone        String        @default("UTC")
  status          FlowStatus    @default(DRAFT)
  activeVersionId String?       @unique
  archivedAt      DateTime?
  createdBy       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  versions        FlowVersion[] @relation("FlowVersions")
  activeVersion   FlowVersion?  @relation("FlowActiveVersion", fields: [activeVersionId], references: [id])

  @@index([status, updatedAt])
}

enum FlowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model FlowVersion {
  id             String                @id @default(cuid())
  flowId         String
  versionNumber  Int
  graph          Json
  algorithm      Json
  entryFilters   Json                  @default("{}")
  fallbackPolicy Json                  @default("{}")
  publishedAt    DateTime?
  publishedBy    String?
  createdAt      DateTime              @default(now())
  flow           Flow                  @relation("FlowVersions", fields: [flowId], references: [id], onDelete: Cascade)
  activeFor      Flow?                 @relation("FlowActiveVersion")
  branches       FlowBranch[]
  fallbackSteps  FallbackStep[]
  capDefs        CapDefinition[]
  algoConfigs    FlowAlgorithmConfig[]

  @@unique([flowId, versionNumber])
  @@index([flowId, createdAt])
}

model FlowBranch {
  id                String      @id @default(cuid())
  flowVersionId     String
  nodeId            String
  name              String
  filters           Json        @default("{}")
  algorithmOverride Json?
  order             Int         @default(0)
  flowVersion       FlowVersion @relation(fields: [flowVersionId], references: [id], onDelete: Cascade)

  @@unique([flowVersionId, nodeId])
  @@index([flowVersionId, order])
}

model FlowAlgorithmConfig {
  id            String         @id @default(cuid())
  flowVersionId String
  scope         AlgorithmScope
  scopeRefId    String?
  mode          AlgorithmMode
  params        Json           @default("{}")
  flowVersion   FlowVersion    @relation(fields: [flowVersionId], references: [id], onDelete: Cascade)

  @@unique([flowVersionId, scope, scopeRefId])
}

enum AlgorithmScope {
  FLOW
  BRANCH
}

enum AlgorithmMode {
  WEIGHTED_ROUND_ROBIN
  SLOTS_CHANCE
}

model FallbackStep {
  id            String      @id @default(cuid())
  flowVersionId String
  fromNodeId    String
  toNodeId      String
  hopOrder      Int
  triggers      Json        @default("{}")
  flowVersion   FlowVersion @relation(fields: [flowVersionId], references: [id], onDelete: Cascade)

  @@unique([flowVersionId, fromNodeId, hopOrder])
  @@index([flowVersionId, fromNodeId])
}

model CapDefinition {
  id            String      @id @default(cuid())
  flowVersionId String
  scope         CapScope
  scopeRefId    String
  window        CapWindow
  limit         Int
  timezone      String      @default("UTC")
  perCountry    Boolean     @default(false)
  flowVersion   FlowVersion @relation(fields: [flowVersionId], references: [id], onDelete: Cascade)
  countryLimits CapCountryLimit[]

  @@unique([flowVersionId, scope, scopeRefId, window])
  @@index([flowVersionId, scope])
}

model CapCountryLimit {
  id           String        @id @default(cuid())
  capDefId     String
  country      String
  limit        Int
  capDefinition CapDefinition @relation(fields: [capDefId], references: [id], onDelete: Cascade)

  @@unique([capDefId, country])
  @@index([capDefId])
}

enum CapWindow {
  HOURLY
  DAILY
  WEEKLY
}

model CapCounter {
  id        String    @id @default(cuid())
  scope     CapScope
  scopeId   String
  window    CapWindow
  bucketKey String
  country   String    @default("")
  count     Int       @default(0)
  resetsAt  DateTime

  @@unique([scope, scopeId, window, bucketKey, country])
  @@index([resetsAt])
}

// --- EPIC-03 Broker Integration ---

model BrokerTemplate {
  id                 String         @id @default(cuid())
  slug               String         @unique
  name               String
  vendor             String
  vertical           String
  protocol           String
  status             String         @default("active")
  countries          String[]
  description        String?
  logoUrl            String?
  docsUrl            String?
  defaultHttpMethod  HttpMethod     @default(POST)
  defaultHeaders     Json           @default("{}")
  defaultAuthType    BrokerAuthType @default(NONE)
  authConfigSchema   Json           @default("{}")
  fieldMapping       Json
  requiredFields     String[]
  staticPayload      Json           @default("{}")
  responseIdPath     String?
  postbackLeadIdPath String
  postbackStatusPath String
  statusMapping      Json
  rateLimitPerMin    Int?
  samplePayload      Json
  sampleResponse     Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  brokers            Broker[]

  @@index([vertical, status])
  @@index([protocol, status])
  @@index([countries])
  @@index([name])
}

model BrokerHealthCheck {
  id         String   @id @default(cuid())
  brokerId   String
  status     String
  latencyMs  Int
  httpStatus Int?
  errorText  String?
  checkedAt  DateTime @default(now())
  broker     Broker   @relation(fields: [brokerId], references: [id], onDelete: Cascade)

  @@index([brokerId, checkedAt])
}

model BrokerErrorSample {
  id                String   @id @default(cuid())
  brokerId          String
  bucketStart       DateTime
  bucketIntervalSec Int
  totalPushes       Int      @default(0)
  successPushes     Int      @default(0)
  errorPushes       Int      @default(0)
  timeoutPushes     Int      @default(0)
  latencyP95Ms      Int?
  topErrorCodes     Json     @default("[]")
  createdAt         DateTime @default(now())
  broker            Broker   @relation(fields: [brokerId], references: [id], onDelete: Cascade)

  @@unique([brokerId, bucketStart, bucketIntervalSec])
  @@index([brokerId, bucketStart])
}
